#include <stdio.h>
void trocarValores(int *a, int *b) {
    int temp;
    temp = *a; 
    *a = *b;   
    *b = temp; 
     printf("Dentro da funcao: a = %d, b = %d\n", *a, *b);
}
int main() {
    int x = 5, y = 10;
    printf("Antes da troca: x = %d, y = %d\n", x, y);
    trocarValores(&x, &y);
    printf("Depois da troca na main: x = %d, y = %d\n", x, y);
    return 0;
}
